# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development                # development | production

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_SSL=false                        # set to true for Supabase / Neon / RDS

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_strong_random_secret
JWT_REFRESH_SECRET=replace_with_another_strong_random_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ─── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com
# SKIP_EMAIL=true                   # uncomment to skip sending emails (dev/test)

# ─── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173  # production: https://yourdomain.com

# ─── Auth ──────────────────────────────────────────────────────────────────────
PASSWORD_RESET_TOKEN_EXPIRY=15m

# ─── Verification rules ────────────────────────────────────────────────────────
VERIFICATION_WINDOW_DAYS=2
VERIFICATION_MIN_VOTES_COMMUNITY=3
VERIFICATION_MIN_VOTES_AUTHORITY=3
VERIFICATION_CONFIRM_THRESHOLD=0.6
VERIFICATION_RADIUS_KM=2

# ─── Points ────────────────────────────────────────────────────────────────────
POINTS_COMMUNITY_FIX=25
POINTS_VERIFICATION=5
POINTS_REPORT=10
